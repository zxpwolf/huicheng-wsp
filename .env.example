# ============================================
# 荟城减重 WSP 系统 - 环境变量配置
# ============================================
# 复制此文件为 .env 并修改相应的值

# --------------------------------------------
# MySQL 数据库配置
# --------------------------------------------
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DATABASE=huicheng_wsp
MYSQL_USER=wsp_user
MYSQL_PASSWORD=wsp123456
MYSQL_PORT=3306

# --------------------------------------------
# Web 应用配置
# --------------------------------------------
WEB_PORT=5000
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# --------------------------------------------
# Nginx 配置（生产环境）
# --------------------------------------------
NGINX_PORT=80
NGINX_SSL_PORT=443

# --------------------------------------------
# 其他配置
# --------------------------------------------
# 时区
TZ=Asia/Shanghai
